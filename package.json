{
  "name": "@deadendjs/swagger-jsdoc",
  "description": "Generates swagger doc based on JSDoc",
  "private": false,
  "version": "8.1.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node examples/app/app.js",
    "lint": "eslint .",
    "test:unit": "vitest run",
    "test": "npm run lint && npm run test:unit",
    "prepare": "husky"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "bin": {
    "swagger-jsdoc": "bin/swagger-jsdoc.js"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "commander": "^14.0.0",
    "doctrine": "3.0.0",
    "glob": "^12.0.0",
    "yaml": "2.0.0-4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/node": "^20.19.4",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.5",
    "express": "4.22.1",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "prettier": "^3.5.3",
    "supertest": "^7.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "vitest": "^4.0.0"
  },
  "license": "MIT",
  "homepage": "https://github.com/deadendjs/swagger-jsdoc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deadendjs/swagger-jsdoc.git"
  },
  "keywords": [
    "swagger",
    "openapi",
    "jsdoc"
  ],
  "author": "https://github.com/deadendjs/swagger-jsdoc/graphs/contributors",
  "bugs": {
    "url": "https://github.com/deadendjs/swagger-jsdoc/issues"
  },
  "lint-staged": {
    "*.{js,json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
